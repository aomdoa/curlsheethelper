{
  "name": "@curlsheethelper/backend",
  "version": "1.0.0",
  "description": "The backend restful service that performs the real work",
  "main": "dist/index.js",
  "scripts": {
    "clean": "rimraf ./dist ./build",
    "lint": "yarn eslint --ext .ts ./src",
    "spell": "cspell ./src/**/*.ts",
    "pretty": "prettier --write ./src/**/*.ts",
    "build": "yarn clean && yarn lint && yarn pretty && yarn spell && tsc --noEmit && ./_scripts/build.sh",
    "deploy": "bash _scripts/deploy.sh",
    "dev": "NODE_ENV=development npx tsx _scripts/run-local.ts"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.1021.0",
    "@aws-sdk/lib-dynamodb": "^3.1021.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/aws-lambda": "^8.10.140",
    "@types/node": "^25.5.0",
    "cspell": "^9.7.0",
    "esbuild": "^0.27.4",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "express": "^5.2.1",
    "globals": "^17.3.0",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.3",
    "tsx": "^4.0.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0"
  }
}
